---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import { getProfile, getPageContent } from '../lib/content';
import { marked } from 'marked';

const [profile, content] = await Promise.all([getProfile(), getPageContent('home')]);

const initials = (profile?.full_name ?? '')
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase())
  .join('');
---

<Base title={`${profile?.full_name ?? 'Home'} — jahuntsmith`} description={profile?.summary}>
  <div class="wrap">
    <section class="hero">
      {profile?.avatar_url ? (
        <img class="hero-image" src={profile.avatar_url} alt={profile.full_name} />
      ) : (
        <div class="hero-placeholder">{initials || '—'}</div>
      )}
      <div class="hero-content">
        <h1>{profile?.full_name}</h1>
        <p class="subtitle">{profile?.headline}</p>
        <p class="bio" set:html={marked.parseInline(profile?.summary ?? '')} />
        <div class="hero-actions">
          {profile?.email && <a href={`mailto:${profile.email}`}>{profile.email}</a>}
          {(profile?.links ?? []).map((l) => (
            <a href={l.url} target="_blank" rel="noopener">{l.label}</a>
          ))}
          {profile?.resume_pdf_url && (
            <a class="btn-download" href={profile.resume_pdf_url} download>Download résumé (PDF)</a>
          )}
        </div>
      </div>
    </section>

    {content?.sections.map((s) => <Section section={s} />)}
  </div>
</Base>
