# ── Build-time read (public site) ─────────────────────────────
# Owner connection string. Reads content from Neon during the Astro build.
# Stored as a GitHub Actions secret named DATABASE_URL — never shipped to the browser.
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-super-rain-a6o7vmst-pooler.us-west-2.aws.neon.tech/neondb?sslmode=require"

# ── Admin app (browser, safe to expose) ───────────────────────
# These are public by design; access is gated by Neon Auth login + RLS.
VITE_NEON_AUTH_URL="https://ep-super-rain-a6o7vmst.neonauth.us-west-2.aws.neon.tech/neondb/auth"
VITE_NEON_DATA_API_URL="https://ep-super-rain-a6o7vmst.apirest.us-west-2.aws.neon.tech/neondb/rest/v1"
